# Shared
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signhub

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=4000
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
SIGN_URL_BASE=http://localhost:3000/sign
WEB_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000/v1
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# AI Provider Selection
# auto => OpenAI if OPENAI_API_KEY exists, else Ollama if reachable, else heuristic
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# S3 / MinIO
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
S3_BUCKET=signhub
S3_ENDPOINT=http://localhost:9000
LOCAL_FILE_STORAGE=true
LOCAL_STORAGE_PATH=.local-storage

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
